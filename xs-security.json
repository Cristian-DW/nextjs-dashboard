{
  "xsappname": "deltux-pos-auth",
  "tenant-mode": "dedicated",
  "description": "Security profile of Deltux POS",
  "scopes": [
    {
      "name": "$XSAPPNAME.Admin",
      "description": "Administrator access for all resources"
    },
    {
      "name": "$XSAPPNAME.Cashier",
      "description": "Cashier access for POS operations"
    }
  ],
  "attributes": [],
  "role-templates": [
    {
      "name": "AdminRole",
      "description": "Administrator Role Template",
      "scope-references": [
        "$XSAPPNAME.Admin"
      ]
    },
    {
      "name": "CashierRole",
      "description": "Cashier Role Template",
      "scope-references": [
        "$XSAPPNAME.Cashier"
      ]
    }
  ],
  "oauth2-configuration": {
    "redirect-uris": [
      "https://*.cfapps.us10-001.hana.ondemand.com/login/callback"
    ]
  }
}
